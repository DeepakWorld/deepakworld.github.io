<!DOCTYPE html>
<html>
<head>
  <title>Web Image & Video Resizer</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 20px; }
    #canvas { border: 1px solid #ccc; margin-top: 10px; display: block; }
    .section { margin: 30px 0; }
    .control { margin: 15px 0; }
    #progressContainer { width: 100%; background: #eee; margin-top: 10px; }
    #progressBar { width: 0%; height: 20px; background: #4caf50; text-align: center; color: white; }
    .drop-zone {
      border: 2px dashed #aaa;
      padding: 20px;
      text-align: center;
      cursor: pointer;
      margin-bottom: 10px;
    }
    .drop-zone.dragover {
      background: #f0f0f0;
      border-color: #4caf50;
    }
  </style>
</head>
<body>
  <h1>Web-Based Image & Video Resizer</h1>

  <!-- IMAGE SECTION -->
  <div class="section">
    <h2>Image Compression</h2>
    <div id="imageDrop" class="drop-zone">Drag & Drop Image Here or Click</div>
    <input type="file" id="uploadImage" accept="image/*" hidden>
    <br>
    Quality: <input type="range" id="quality" min="0.1" max="1" step="0.1" value="0.8">
    <span id="qualityVal">0.8</span><br>
    <canvas id="canvas"></canvas><br>
    <button onclick="downloadImage()">Download Compressed Image</button>
  </div>

  <!-- VIDEO SECTION -->
  <div class="section">
    <h2>Video Compression (MP4/AVI)</h2>
    <div id="videoDrop" class="drop-zone">Drag & Drop Video Here or Click</div>
    <input type="file" id="uploadVideo" accept="video/*" hidden>
    <br>

    Resolution Scale: <input type="range" id="scale" min="0.25" max="1" step="0.25" value="1">
    <span id="scaleVal">1x</span><br>

    Quality (CRF): <input type="range" id="crf" min="18" max="35" step="1" value="28">
    <span id="crfVal">28</span><br>

    <button onclick="compressVideo()">Compress Video</button><br><br>

    <!-- Progress bar -->
    <div id="progressContainer">
      <div id="progressBar">0%</div>
    </div>

    <video id="videoPreview" controls width="480"></video>
  </div>

  <!-- FFmpeg.js -->
  <script src="https://unpkg.com/@ffmpeg/ffmpeg@0.12.2/dist/ffmpeg.min.js"></script>

  <script>
    // IMAGE COMPRESSION
    const uploadImage = document.getElementById("uploadImage");
    const imageDrop = document.getElementById("imageDrop");
    const canvas = document.getElementById("canvas");
    const ctx = canvas.getContext("2d");
    const qualitySlider = document.getElementById("quality");
    const qualityVal = document.getElementById("qualityVal");
    let img = new Image();

    // Drag & Drop for Image
    imageDrop.addEventListener("click", () => uploadImage.click());
    imageDrop.addEventListener("dragover", e => {
      e.preventDefault();
      imageDrop.classList.add("dragover");
    });
    imageDrop.addEventListener("dragleave", () => imageDrop.classList.remove("dragover"));
    imageDrop.addEventListener("drop", e => {
      e.preventDefault();
      imageDrop.classList.remove("dragover");
      uploadImage.files = e.dataTransfer.files;
      loadImage();
    });
    uploadImage.addEventListener("change", loadImage);

    function loadImage() {
      const file = uploadImage.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = function(e) {
        img.onload = function() {
          canvas.width = img.width;
          canvas.height = img.height;
          ctx.drawImage(img, 0, 0);
        };
        img.src = e.target.result;
      };
      reader.readAsDataURL(file);
    }

    qualitySlider.addEventListener("input", function() {
      qualityVal.textContent = this.value;
    });

    function downloadImage() {
      const link = document.createElement("a");
      link.download = "compressed.jpg";
      link.href = canvas.toDataURL("image/jpeg", parseFloat(qualitySlider.value));
      link.click();
    }

    // VIDEO COMPRESSION
    const uploadVideo = document.getElementById("uploadVideo");
    const videoDrop = document.getElementById("videoDrop");
    const { createFFmpeg, fetchFile } = FFmpeg;
    const ffmpeg = createFFmpeg({ log: true });
    const videoPreview = document.getElementById("videoPreview");
    const scaleSlider = document.getElementById("scale");
    const scaleVal = document.getElementById("scaleVal");
    const crfSlider = document.getElementById("crf");
    const crfVal = document.getElementById("crfVal");
    const progressBar = document.getElementById("progressBar");

    // Drag & Drop for Video
    videoDrop.addEventListener("click", () => uploadVideo.click());
    videoDrop.addEventListener("dragover", e => {
      e.preventDefault();
      videoDrop.classList.add("dragover");
    });
    videoDrop.addEventListener("dragleave", () => videoDrop.classList.remove("dragover"));
    videoDrop.addEventListener("drop", e => {
      e.preventDefault();
      videoDrop.classList.remove("dragover");
      uploadVideo.files = e.dataTransfer.files;
    });

    scaleSlider.addEventListener("input", () => scaleVal.textContent = scaleSlider.value + "x");
    crfSlider.addEventListener("input", () => crfVal.textContent = crfSlider.value);

    async function compressVideo() {
      await ffmpeg.load();
      const file = uploadVideo.files[0];
      if (!file) return alert("Please upload a video first!");

      ffmpeg.FS('writeFile', 'input.mp4', await fetchFile(file));

      const scaleFactor = scaleSlider.value;
      const crfValue = crfSlider.value;

      ffmpeg.setLogger(({ type, message }) => {
        if (type === 'fferr' || type === 'ffout') {
          if (message.includes("frame=")) {
            let match = message.match(/frame=\s*(\d+)/);
            if (match) {
              let frame = parseInt(match[1]);
              let percent = Math.min(100, Math.round(frame / 100));
              progressBar.style.width = percent + "%";
              progressBar.textContent = percent + "%";
            }
          }
        }
      });

      await ffmpeg.run(
        '-i', 'input.mp4',
        '-vf', `scale=iw*${scaleFactor}:ih*${scaleFactor}`,
        '-vcodec', 'libx264',
        '-crf', crfValue,
        'output.mp4'
      );

      const data = ffmpeg.FS('readFile', 'output.mp4');
      const videoURL = URL.createObjectURL(new Blob([data.buffer], { type: 'video/mp4' }));
      videoPreview.src = videoURL;

      const link = document.createElement("a");
      link.download = "compressed.mp4";
      link.href = videoURL;
      link.click();

      progressBar.style.width = "100%";
      progressBar.textContent = "Done";
    }
  </script>
</body>
</html>
